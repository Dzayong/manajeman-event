# Database (XAMPP MySQL local, atau hosted MySQL untuk deploy)
DATABASE_URL="mysql://root:@localhost:3306/hmif_kepanitiaan"

# Auth — generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SECRET="ganti-dengan-random-hex-64-karakter"

# OpenAI — dipanggil server-side saja. AI_MOCK=true memakai contoh JSON tanpa kuota
OPENAI_API_KEY="sk-..."
AI_MOCK="true"

# Gmail SMTP (akun sistem + App Password, bukan password biasa)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="465"
SMTP_USER="akun.sistem@gmail.com"
SMTP_PASS="app-password-16-karakter"
EMAIL_MOCK="true"

# App
APP_URL="http://localhost:3000"
