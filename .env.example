# Database (XAMPP MySQL local)
DATABASE_URL="mysql://root:@localhost:3306/hmif_kepanitiaan"

# Auth — generate your own with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SECRET=""

# OpenAI — server-side only. AI_MOCK=true returns sample JSON (no quota spent)
OPENAI_API_KEY=""
AI_MOCK="true"

# Gmail SMTP (isi dengan akun sistem + app password)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="465"
SMTP_USER=""
SMTP_PASS=""
EMAIL_MOCK="true"

# App
APP_URL="http://localhost:3000"